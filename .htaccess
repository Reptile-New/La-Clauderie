# Config Apache pour l'hébergement OVH (laclauderie.fr).
# Déployé à la racine du site par .github/workflows/deploy-ovh.yml
# (GitHub Pages l'ignore : il n'est pas copié dans son artefact).

AddDefaultCharset UTF-8

# En-têtes de sécurité (sans effet si mod_headers est absent, grâce au IfModule).
<IfModule mod_headers.c>
  # Empêche le navigateur de « deviner » un type de fichier différent de celui annoncé.
  Header set X-Content-Type-Options "nosniff"
  # Le site ne s'affiche pas dans une iframe d'un autre site (anti-clickjacking).
  Header set X-Frame-Options "SAMEORIGIN"
  # Les liens sortants ne transmettent que le domaine, pas l'URL complète.
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

RewriteEngine On

# www.laclauderie.fr → laclauderie.fr
RewriteCond %{HTTP_HOST} ^www\.laclauderie\.fr$ [NC]
RewriteRule ^(.*)$ http://laclauderie.fr/$1 [R=301,L]

# http → https désactivé temporairement : le certificat Let's Encrypt
# fourni par OVH n'est pas encore actif, la redirection forcée casse
# l'accès au site tant qu'il n'est pas généré. À réactiver une fois le
# certificat actif (onglet SSL de l'hébergement OVH) :
#
# RewriteCond %{HTTPS} !=on
# RewriteRule ^(.*)$ https://laclauderie.fr/$1 [R=301,L]

