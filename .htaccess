# Config Apache pour l'hébergement OVH (laclauderie.fr).
# Déployé à la racine du site par .github/workflows/deploy-ovh.yml
# (GitHub Pages l'ignore : il n'est pas copié dans son artefact).

AddDefaultCharset UTF-8

# En-têtes de sécurité (sans effet si mod_headers est absent, grâce au IfModule).
<IfModule mod_headers.c>
  # Empêche le navigateur de « deviner » un type de fichier différent de celui annoncé.
  Header set X-Content-Type-Options "nosniff"
  # Le site ne s'affiche pas dans une iframe d'un autre site (anti-clickjacking).
  Header set X-Frame-Options "SAMEORIGIN"
  # Les liens sortants ne transmettent que le domaine, pas l'URL complète.
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  # Le navigateur retient (1 an) que le site est en HTTPS et n'essaie plus
  # jamais le HTTP. Le header est envoyé sans condition : sur une réponse
  # HTTP il est ignoré par les navigateurs (conforme à la spec), et l'ancien
  # garde « env=HTTPS » dépendait d'une variable d'environnement que le
  # front OVH ne pose pas forcément — le header pouvait ne jamais partir.
  Header always set Strict-Transport-Security "max-age=31536000"
</IfModule>

RewriteEngine On

# http → https (certificat Let's Encrypt OVH actif — vérifié).
# Le nom de domaine canonique est forcé au passage : http://www.… arrive
# directement sur https://laclauderie.fr en une seule redirection.
RewriteCond %{HTTPS} !=on
RewriteRule ^(.*)$ https://laclauderie.fr/$1 [R=301,L]

# https://www.laclauderie.fr → https://laclauderie.fr
RewriteCond %{HTTP_HOST} ^www\.laclauderie\.fr$ [NC]
RewriteRule ^(.*)$ https://laclauderie.fr/$1 [R=301,L]

